{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; /usr/bin/python3 \"$root/.codex/hooks/secret_scan.py\"",
            "timeout": 10,
            "statusMessage": "Scanning prompt for secret-shaped text"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|^apply_patch$|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; /usr/bin/python3 \"$root/.codex/hooks/secret_scan.py\"",
            "timeout": 10,
            "statusMessage": "Scanning tool use for secret-shaped text"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; /usr/bin/python3 \"$root/.codex/hooks/subagent_start_context.py\"",
            "timeout": 10,
            "statusMessage": "Adding Mamkin subagent handoff context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "root=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; /usr/bin/python3 \"$root/.codex/hooks/stop_process_check.py\"",
            "timeout": 10,
            "statusMessage": "Checking Mamkin turn closeout"
          }
        ]
      }
    ]
  }
}
